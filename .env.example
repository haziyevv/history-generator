# Copy this file to .env and fill in your keys.
# The pipeline runs without keys (it emits labelled placeholders), so you can
# test the wiring first and add keys stage-by-stage.

# Script + metadata stages (Anthropic Claude)
ANTHROPIC_API_KEY=

# Narration + music + SFX (ElevenLabs)
ELEVENLABS_API_KEY=
# Optional: a specific Turkish-capable voice id; leave blank for the default.
ELEVENLABS_VOICE_ID=

# AI images + image->video (fal.ai)
FAL_KEY=
